      "title": "Répartition des postures",
      "type": "piechart",
      "datasource": {"type": "postgres", "uid": "velvet-pg"},
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 9},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "velvet-pg"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT posture, count(*)::int AS \"Nombre\" FROM health_data WHERE $__timeFilter(recorded_at) AND posture IS NOT NULL GROUP BY posture ORDER BY \"Nombre\" DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["sum"], "fields": "/^Nombre$/", "values": true},
        "pieType": "pie",
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      }
    },
    {
      "id": 5,
      "title": "Dernières mesures",
      "type": "table",
      "datasource": {"type": "postgres", "uid": "velvet-pg"},
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 8},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "velvet-pg"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT hd.recorded_at AS \"Horodatage\", u.email AS \"Utilisateur\", hd.heart_rate AS \"Fréquence (bpm)\", CASE WHEN hd.fall_detected THEN '⚠ OUI' ELSE 'non' END AS \"Chute\", hd.posture AS \"Posture\" FROM health_data hd JOIN users u ON u.id = hd.user_id WHERE $__timeFilter(hd.recorded_at) ORDER BY hd.recorded_at DESC LIMIT 30",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Chute"},
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "red", "value": "⚠ OUI"}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Fréquence (bpm)"},
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 100},
                    {"color": "red", "value": 130}
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-background"}
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Horodatage", "desc": true}]
      }
    }
