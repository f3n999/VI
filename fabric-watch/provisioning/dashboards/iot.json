      "id": 1,
      "title": "Fréquence cardiaque (7 jours)",
      "type": "timeseries",
      "datasource": {"type": "postgres", "uid": "velvet-pg"},
      "gridPos": {"x": 0, "y": 0, "w": 16, "h": 9},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "velvet-pg"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT recorded_at AS \"time\", heart_rate AS \"Jean Dupont\" FROM health_data WHERE user_id = 3 AND $__timeFilter(recorded_at) ORDER BY recorded_at",
          "refId": "A"
        },
        {
          "datasource": {"type": "postgres", "uid": "velvet-pg"},
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT recorded_at AS \"time\", heart_rate AS \"Marie Martin\" FROM health_data WHERE user_id = 4 AND $__timeFilter(recorded_at) ORDER BY recorded_at",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisLabel": "bpm",
            "thresholdsStyle": {"mode": "line"}
          },
          "unit": "short",
